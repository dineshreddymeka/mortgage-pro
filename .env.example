# Copy to `.env.local` for local Vite (never commit real keys).
# Browser keys are visible in the client bundle — restrict them in Google Cloud Console / Firebase App Check.

VITE_GOOGLE_MAPS_API_KEY=

# Firebase web app config (client SDK only — never put the Admin service-account private key here).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional server-side estimate proxy (Firebase Functions or compatible API).
# Example: https://us-central1-your-project.cloudfunctions.net
# Leave blank to use offline heuristic stubs only.
VITE_ESTIMATE_API_BASE_URL=
# Client fetch timeout for estimate proxy (milliseconds, default 12000).
VITE_ESTIMATE_API_TIMEOUT_MS=12000

# Optional per-house tax research proxy (official .gov/.edu links).
# Prefer this over VITE_ESTIMATE_API_BASE_URL when set; same Functions project is typical.
# Example: https://us-central1-your-project.cloudfunctions.net
VITE_TAX_RESEARCH_API_BASE_URL=
# Client fetch timeout for tax research collect (milliseconds, default 35000).
VITE_TAX_RESEARCH_API_TIMEOUT_MS=35000
