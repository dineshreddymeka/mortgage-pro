# Copy to `.env` for local emulator runs (never commit real secrets).
# Firebase CLI loads these for `firebase emulators:start --only functions`.

# Comma-separated browser origins allowed for CORS (no trailing slash).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://dineshreddymeka.github.io

# Per-IP requests per rolling minute window (default 60).
RATE_LIMIT_PER_IP=60

# Optional per-user header limit when `X-Estimate-User-Id` is sent (default 120).
RATE_LIMIT_PER_USER=120

# Upstream fetch timeout in milliseconds (default 8000).
UPSTREAM_TIMEOUT_MS=8000

# Server-side response cache TTL in seconds (default 21600 = 6 hours).
# Also reused for per-house tax research snapshot TTL (scenario.research.externalTaxResearch).
CACHE_TTL_SECONDS=21600

# --- Optional upstream providers (leave blank to use server heuristics) ---

# Mortgage rates proxy (expects JSON: { "apr": number } or { "rate": number }).
MORTGAGE_RATES_API_URL=
MORTGAGE_RATES_API_KEY=

# Property tax proxy (expects JSON with annualTax or taxAnnual field).
PROPERTY_TAX_API_URL=
PROPERTY_TAX_API_KEY=

# Insurance proxy (expects JSON with annualPremium or insuranceAnnual).
INSURANCE_API_URL=
INSURANCE_API_KEY=

# Rent estimate proxy (expects JSON with monthlyRent or rent).
RENT_ESTIMATE_API_URL=
RENT_ESTIMATE_API_KEY=

# Comps / valuation proxy (expects JSON with value or estimatedValue).
COMPS_API_URL=
COMPS_API_KEY=
